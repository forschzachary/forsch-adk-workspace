# ScreeningRoom bots — environment template.
#
# Copy to deploy/screeningroom.env and fill in REAL values on the box.
#   cp deploy/screeningroom.env.example deploy/screeningroom.env
# deploy/screeningroom.env is gitignored — NEVER commit it, never echo a token.
#
# This file lists every variable the bots read, BY NAME ONLY. Secrets are left
# blank; non-secret public ids/defaults are shown as a convenience and may be edited.
# The `sr` CLI's own creds are NOT here — they live in cli.json (see REPO-SYNC.md).

# ── Gateway (LiteLLM) — REQUIRED ──────────────────────────────────────────────
# discord_main.py hard-fails at boot if LITELLM_BASE_URL is unset.
# Models default to openai/gpt-5.5 via this gateway (cat_persona/ops_persona).
# HEADS-UP: from Hetzner this is the likeliest connectivity blocker — confirm egress.
LITELLM_BASE_URL=
LITELLM_HERMES_KEY=
# Optional alias the code also accepts if LITELLM_HERMES_KEY is unset:
# LITELLM_API_KEY=

# ── Huberto (friend-facing cat, DM-only) — REQUIRED ───────────────────────────
HUBERTO_DISCORD_BOT_TOKEN=
# Non-secret public bot id (identity guard fails closed if it mismatches):
HUBERTO_EXPECTED_BOT_ID=1499544375204773969

# ── screening_ops (internal lead, team-social channel) — REQUIRED ─────────────
COMPANION_LEAD_DISCORD_BOT_TOKEN=
COMPANION_LEAD_EXPECTED_BOT_ID=1512599235910963371
# Channel the ops lead posts to (non-secret Discord channel id):
OPS_CHANNEL_ID=1511377396668825662

# ── Admin recognition — REQUIRED ──────────────────────────────────────────────
# Comma-separated Discord ids treated as admins (invite/suspend/audit gates).
# Zach's id is the known value; not a secret.
SR_ADMIN_DISCORD_IDS=175984567176527873

# ── Curator (3rd bot, SR-1 showrunner) — OPTIONAL (Phase 6) ───────────────────
# Leave the token BLANK to run on two bots. If set, CURATOR_EXPECTED_BOT_ID is
# mandatory (the bot SystemExits otherwise).
CURATOR_DISCORD_BOT_TOKEN=
CURATOR_EXPECTED_BOT_ID=
# Channel for the curator (#screening-tv); falls back to team-social until it exists:
TV_CHANNEL_ID=1511377396668825662

# ── sr CLI location — set by docker-compose; override only off-container ───────
# In the container this is /screening-room/scripts/sr (set in docker-compose.yml).
# For a bare systemd run, point it at the cloned repo path:
# SR_CLI=/opt/screeningroom/screening-room/scripts/sr

# ── Compose-only path knobs (used by docker-compose.yml, NOT read by Python) ──
# Absolute host paths; override the relative defaults in docker-compose.yml.
# FORSCH_WORKSPACE=/opt/screeningroom/forsch-adk-workspace
# SCREENING_ROOM_REPO=/opt/screeningroom/screening-room
# SR_CLI_CONFIG=/opt/screeningroom/secrets/cli.json
